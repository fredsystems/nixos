{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "config:best-practices",
    "default:pinDigestsDisabled",
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    schedule: ["* 12 * * 0"],
  },
  timezone: "Etc/UTC",
  schedule: ["* 12 * * 0"],
  enabledManagers: ["custom.regex", "nix", "github-actions"],
  prConcurrentLimit: 0,
  prHourlyLimit: 0,
  prCreation: "immediate",
  automerge: true,
  platformAutomerge: true,
  nix: {
    enabled: true,
  },
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/systems-linux/(.*)/configuration\\.nix$/"],
      matchStrings: [
        'image = "v?(?<depName>.*?):(?<currentValue>.*?)(?:@(?<currentDigest>sha256:[a-f0-9]+))?";',
      ],
      datasourceTemplate: "docker",
      depTypeTemplate: "container",
      depNameTemplate: "{{depName}}",
      packageNameTemplate: "{{depName}}",
      versioningTemplate: "loose",
    },
  ],
  packageRules: [
    {
      matchManagers: ["github-actions", "nix"],
      matchUpdateTypes: ["major", "minor", "patch", "pin"],
      automerge: true,
    },
    {
      matchCategories: ["docker"],
      enabled: true,
      automerge: true,
    },
    {
      matchDatasources: ["docker"],
      versioning: "regex:^(telegraf|v\\d+-latest|latest)-build-(?<major>\\d+)$",
      matchPackageNames: ["/^ghcr\\.io/sdr-enthusiasts/.+$/"],
      automerge: true,
    },
    {
      matchDatasources: ["docker"],
      versioning: "regex:^(trixie-)?latest-build-(?<major>\\d+)?$",
      matchPackageNames: ["ghcr.io/fredsystems/{/,}**"],
      automerge: true,
    },
    {
      matchDatasources: ["docker"],
      versioning: "regex:^(trixie-)?latest-build-(?<major>\\d+)?$",
      matchPackageNames: ["ghcr.io/rpatel3001/{/,}**"],
      automerge: true,
    },
    {
      matchDatasources: ["docker"],
      versioning: "regex:^(trixie-)?latest-build-(?<major>\\d+)?$",
      matchPackageNames: ["ghcr.io/plane-watch/{/,}**"],
      automerge: true,
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["amir20/dozzle"],
      automerge: true,
    },
  ],
}
